<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Checklist — Colocación de catéter de HD</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    background: linear-gradient(135deg, #eaf4f8 0%, #f5f9fc 100%);
    min-height: 100vh;
    padding: 24px 16px;
    color: #1a3a4a;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  header {
    text-align: center;
    margin-bottom: 28px;
  }

  h1 {
    font-size: 1.75rem;
    color: #0d4b66;
    font-weight: 600;
    margin-bottom: 6px;
  }

  .subtitle {
    color: #5a7a88;
    font-size: 0.95rem;
    margin-bottom: 18px;
  }

  .status-bar {
    background: white;
    border-radius: 12px;
    padding: 16px 20px;
    box-shadow: 0 2px 8px rgba(13, 75, 102, 0.08);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }

  .counter {
    font-size: 1.05rem;
    font-weight: 500;
    color: #0d4b66;
  }

  .counter strong {
    color: #1a8cab;
    font-size: 1.25rem;
  }

  .progress-bar {
    flex: 1;
    min-width: 180px;
    height: 8px;
    background: #e0eef3;
    border-radius: 4px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, #1a8cab, #2bb3a8);
    border-radius: 4px;
    transition: width 0.4s ease;
    width: 0%;
  }

  .reset-btn {
    background: #0d4b66;
    color: white;
    border: none;
    padding: 8px 18px;
    border-radius: 8px;
    font-size: 0.9rem;
    cursor: pointer;
    transition: background 0.2s;
    font-weight: 500;
  }

  .reset-btn:hover {
    background: #1a8cab;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
    gap: 14px;
    margin-top: 24px;
  }

  .card {
    background: white;
    border-radius: 12px;
    padding: 16px 12px;
    box-shadow: 0 2px 6px rgba(13, 75, 102, 0.07);
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s, opacity 0.4s, max-height 0.4s, padding 0.4s, margin 0.4s;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    border: 2px solid transparent;
    user-select: none;
  }

  .card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(13, 75, 102, 0.15);
    border-color: #1a8cab;
  }

  .card:active {
    transform: translateY(0);
  }

  .card.removing {
    opacity: 0;
    transform: scale(0.85);
    max-height: 0;
    padding-top: 0;
    padding-bottom: 0;
    margin: 0;
    border-width: 0;
    pointer-events: none;
  }

  .icon {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #1a8cab;
  }

  .icon svg {
    width: 100%;
    height: 100%;
  }

  .label {
    font-size: 0.92rem;
    font-weight: 500;
    color: #1a3a4a;
    line-height: 1.25;
  }

  .qty {
    display: inline-block;
    background: #e0f2f7;
    color: #0d4b66;
    font-size: 0.78rem;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 10px;
    margin-top: 2px;
  }

  .complete-message {
    background: linear-gradient(135deg, #2bb3a8, #1a8cab);
    color: white;
    border-radius: 12px;
    padding: 32px;
    text-align: center;
    margin-top: 20px;
    box-shadow: 0 4px 16px rgba(26, 140, 171, 0.3);
    display: none;
    animation: fadeIn 0.5s ease;
  }

  .complete-message.show {
    display: block;
  }

  .complete-message h2 {
    font-size: 1.5rem;
    margin-bottom: 8px;
    font-weight: 600;
  }

  .complete-message p {
    opacity: 0.95;
    font-size: 1rem;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 480px) {
    h1 { font-size: 1.4rem; }
    .grid { grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 10px; }
    .card { padding: 12px 8px; }
    .icon { width: 44px; height: 44px; }
    .label { font-size: 0.85rem; }
  }
</style>
</head>
<body>
<div class="container">
  <header>
    <h1>Colocación de catéter de hemodiálisis</h1>
    <p class="subtitle">Tocá cada ítem a medida que lo prepares</p>
  </header>

  <div class="status-bar">
    <div class="counter"><strong id="pending">20</strong> de <span id="total">20</span> ítems pendientes</div>
    <div class="progress-bar"><div class="progress-fill" id="progress"></div></div>
    <button class="reset-btn" id="resetBtn">Reiniciar</button>
  </div>

  <div class="grid" id="grid"></div>

  <div class="complete-message" id="completeMsg">
    <h2>Listo para procedimiento</h2>
    <p>Todos los insumos preparados. Verificá una vez más antes de iniciar.</p>
  </div>
</div>

<script>
  const items = [
    { name: "Ecógrafo", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="14" height="10" rx="1.5"/><path d="M17 9h3v6a2 2 0 0 1-2 2h-1"/><path d="M7 17v3M13 17v3M5 20h10"/><path d="M6 8l2 2 2-3 2 4 2-2"/></svg>` },
    { name: "Funda de ecógrafo", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M7 3h10l-1 6c0 3-2 5-4 5s-4-2-4-5z"/><path d="M11 14v7M9 21h4"/></svg>` },
    { name: "Gel", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3h6v3H9z"/><path d="M8 6h8v14a1 1 0 0 1-1 1H9a1 1 0 0 1-1-1z"/><path d="M10 12h4M10 16h4"/></svg>` },
    { name: "Pañal", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8c4 0 8 2 9 4 1-2 5-4 9-4v6c-4 0-8 2-9 4-1-2-5-4-9-4z"/><path d="M12 12v4"/></svg>` },
    { name: "KIT colocación (bandeja)", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="8" width="20" height="10" rx="1.5"/><path d="M6 8V6a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v2"/><path d="M6 13h4M14 13h4"/></svg>` },
    { name: "Bowl", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11h18a9 9 0 0 1-18 0z"/><path d="M3 11c0-1 4-2 9-2s9 1 9 2"/></svg>` },
    { name: "Iodo povidona", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M10 2h4v3h-4z"/><path d="M9 5h6v3l1 2v10a2 2 0 0 1-2 2h-4a2 2 0 0 1-2-2V10l1-2z"/><path d="M9 13h6"/></svg>` },
    { name: "Gasas", qty: "x 10", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="1"/><path d="M4 9h16M4 15h16M9 4v16M15 4v16"/></svg>` },
    { name: "Jeringas 10 mL", qty: "x 3", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21l3-3"/><path d="M5 19l8-8"/><path d="M11 13l4-4 4 4-4 4z" transform="rotate(-45 13 13)"/><path d="M14 6l4 4M16 4l4 4M19 7l2 2"/></svg>` },
    { name: "Agujas amarilla/verde", qty: "x 2", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21l4-4"/><path d="M6 18l10-10"/><path d="M14 6l4 4"/><rect x="15" y="3" width="6" height="4" rx="0.5" transform="rotate(45 18 5)"/></svg>` },
    { name: "Aguja naranja", qty: "x 1", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21l4-4"/><path d="M6 18l10-10"/><path d="M14 6l4 4"/><rect x="15" y="3" width="6" height="4" rx="0.5" transform="rotate(45 18 5)"/></svg>` },
    { name: "Catéter", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12h10"/><path d="M14 8v8l4-2-4-2 4-2z" fill="currentColor"/><circle cx="4" cy="12" r="1.5"/><path d="M2 9c0-1 1-2 2-2M2 15c0 1 1 2 2 2"/></svg>` },
    { name: "Bisturí", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21l5-5"/><path d="M8 16l6-6 4 4-6 6z"/><path d="M14 10l4-7 2 2-4 7z"/></svg>` },
    { name: "Solución fisiológica 0,9%", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 2h6v3l-1 2v12a2 2 0 0 1-2 2h-0a2 2 0 0 1-2-2V7l-1-2z"/><path d="M9 12h6"/><path d="M11 15h2"/></svg>` },
    { name: "Tijera", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M8.5 7.5L20 19M8.5 16.5L20 5"/></svg>` },
    { name: "Cinta adhesiva", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="3"/><path d="M12 21v-6"/></svg>` },
    { name: "Hilo de sutura", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12c2-3 4-3 6 0s4 3 6 0 4-3 6 0"/><circle cx="3" cy="12" r="1"/><path d="M21 12l-2-2M21 12l-2 2"/></svg>` },
    { name: "Heparina", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 2h6v3l-1 2v12a2 2 0 0 1-2 2h-0a2 2 0 0 1-2-2V7l-1-2z"/><text x="12" y="15" font-size="5" text-anchor="middle" fill="currentColor" stroke="none">HEP</text></svg>` },
    { name: "Guante estéril", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M7 21V11c0-1 0-2 1-2s1 1 1 2V8c0-1 0-2 1-2s1 1 1 2v-2c0-1 0-2 1-2s1 1 1 2v3c0-1 0-2 1-2s1 1 1 2v3l1 2v6z"/></svg>` },
    { name: "Tegaderm", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="6" width="16" height="12" rx="1" stroke-dasharray="2 2"/><rect x="7" y="9" width="10" height="6" rx="0.5"/></svg>` },
    { name: "Lidocaína", qty: "x 2", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M10 2h4v3h-4z"/><path d="M9 5h6v15a1 1 0 0 1-1 1h-4a1 1 0 0 1-1-1z"/><path d="M9 11h6"/><text x="12" y="17" font-size="4" text-anchor="middle" fill="currentColor" stroke="none">LIDO</text></svg>` },
    { name: "Cofia", qty: "x 2", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14c0-5 3.5-9 8-9s8 4 8 9"/><path d="M3 14h18v2a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><path d="M8 9c1-1 2-1.5 4-1.5s3 .5 4 1.5"/></svg>` },
    { name: "Barbijo", qty: "x 2", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 9c2-1 4-1.5 7-1.5s5 .5 7 1.5v6c-2 1-4 1.5-7 1.5s-5-.5-7-1.5z"/><path d="M5 11h14M5 13h14"/><path d="M5 9L2 8v8l3-1M19 9l3-1v8l-3-1"/></svg>` },
    { name: "Tacho rojo (residuos)", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 7h14l-1 13a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2z"/><path d="M3 7h18"/><path d="M9 7V4h6v3"/><path d="M10 12v6M14 12v6"/></svg>` }
  ];

  const grid = document.getElementById('grid');
  const pendingEl = document.getElementById('pending');
  const totalEl = document.getElementById('total');
  const progressEl = document.getElementById('progress');
  const completeMsg = document.getElementById('completeMsg');
  const resetBtn = document.getElementById('resetBtn');

  const total = items.length;
  totalEl.textContent = total;
  let pending = total;

  function render() {
    grid.innerHTML = '';
    pending = total;
    completeMsg.classList.remove('show');
    updateStatus();

    items.forEach((item, idx) => {
      const card = document.createElement('div');
      card.className = 'card';
      card.dataset.idx = idx;
      card.innerHTML = `
        <div class="icon">${item.icon}</div>
        <div class="label">${item.name}${item.qty ? `<br><span class="qty">${item.qty}</span>` : ''}</div>
      `;
      card.addEventListener('click', () => removeCard(card));
      grid.appendChild(card);
    });
  }

  function removeCard(card) {
    if (card.classList.contains('removing')) return;
    card.classList.add('removing');
    pending--;
    updateStatus();

    setTimeout(() => {
      card.remove();
      if (pending === 0) {
        completeMsg.classList.add('show');
      }
    }, 400);
  }

  function updateStatus() {
    pendingEl.textContent = pending;
    const completed = total - pending;
    progressEl.style.width = `${(completed / total) * 100}%`;
  }

  resetBtn.addEventListener('click', render);

  render();
</script>
</body>
</html>
